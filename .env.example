# notifications — copiá a .env y completá. NUNCA commitees .env (RULE-02: sin secretos en código).

# Superusuario de lab-postgres (lo usa SOLO postgres-setup / control-plane)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Password del rol de app notifications_app (app-plane, sin DDL)
APP_DB_PASSWORD=notifications

# Secreto JWT (debe coincidir con el de IAM para validar tokens)
JWT_SECRET=

# Tenancy: true = multi-tenant con RLS (default). false = single-tenant.
MULTITENANT=true
